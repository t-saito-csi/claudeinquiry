# =============================================================
# 問診システム 環境変数テンプレート
# このファイルをコピーして .env を作成してください:
#   cp .env.example .env
# =============================================================

# ---------------------------
# Database (PostgreSQL 16)
# ---------------------------
DATABASE_URL=postgresql+asyncpg://inquiry_user:inquiry_pass@db:5432/inquiry_db
POSTGRES_USER=inquiry_user
POSTGRES_PASSWORD=inquiry_pass
POSTGRES_DB=inquiry_db

# ---------------------------
# Redis
# ---------------------------
REDIS_URL=redis://redis:6379/0
# 本番環境では必ずパスワードを設定してください
REDIS_PASSWORD=

# ---------------------------
# セキュリティ
# ---------------------------
# openssl rand -hex 32 で生成してください
SECRET_KEY=change_me_generate_with_openssl_rand_hex_32

# AES-256-GCM暗号化キー (本番はKMS/Vault経由で取得)
# openssl rand -base64 32 で生成してください
ENCRYPTION_KEY=change_me_generate_with_openssl_rand_base64_32

# ---------------------------
# Claude API (Anthropic)
# ---------------------------
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# ---------------------------
# HL7 FHIR サーバー
# ---------------------------
FHIR_SERVER_URL=https://fhir.hospital.example.com/fhir/R4
FHIR_CLIENT_ID=
FHIR_CLIENT_SECRET=

# ---------------------------
# アプリケーション
# ---------------------------
ENVIRONMENT=development
# カンマ区切りで複数オリジンを指定可能
ALLOWED_ORIGINS=http://localhost:5173

# ---------------------------
# フロントエンド (Vite)
# ---------------------------
VITE_API_URL=http://localhost:8000
